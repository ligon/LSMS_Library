# Pin .venv to the main working tree so git worktrees share one environment.
_git_common="$(git rev-parse --git-common-dir 2>/dev/null)"
if [ "${_git_common}" = ".git" ]; then
  _main_tree="$(pwd)"
else
  _main_tree="$(dirname "${_git_common}")"
fi
VIRTUAL_ENV="${_main_tree}/.venv"
export VIRTUAL_ENV
if has poetry && has python; then
  layout poetry
else
  log_status "direnv: skipping layout poetry (missing poetry or python)"
  [ -d "${VIRTUAL_ENV}/bin" ] && PATH_add "${VIRTUAL_ENV}/bin"
fi

