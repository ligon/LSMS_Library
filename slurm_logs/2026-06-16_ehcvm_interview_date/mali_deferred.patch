index 67695e91..4103d82c 100644
--- a/lsms_library/countries/Mali/2018-19/_/mapping.py
+++ b/lsms_library/countries/Mali/2018-19/_/mapping.py
@@ -64,10 +64,23 @@ def Age(value):
 
 def interview_date(value):
     '''
-    Column-level pass-through for interview_date.
-    Overrides mali.py's df-level interview_date(df) which expects a DataFrame.
-    The household_roster(df) function handles date parsing via age_handler.
+    Dual-role hook named ``interview_date``.
+
+    As a COLUMN formatter (the ``interview_date: s00q23a`` myvar inside
+    ``household_roster``) it receives a scalar and passes it through; the
+    ``household_roster(df)`` function then parses the date via age_handler.
+
+    As the TABLE-level ``df_edit`` hook for the top-level ``interview_date``
+    table it receives a DataFrame and melts the EHCVM per-visit start/end
+    timestamps onto a ``visit`` index.  q23/q24/q25 a/b = visit 1/2/3
+    start/end -> int_start/int_end[_v2/_v3]; delegates to
+    local_tools.melt_visit_intervals -> 'Interview start' / 'Interview end'.
+    Collapsing ``visit`` with ``first`` reproduces the legacy single-date
+    table.  (Shadows mali.py's country-level interview_date(df), so the melt
+    lives here.)
     '''
+    if isinstance(value, pd.DataFrame):
+        return tools.melt_visit_intervals(value)
     return value
 
 
